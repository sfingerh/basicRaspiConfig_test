[Unit]
Description=SQC Flask Web App
After=network-online.target
Wants=network-online.target

[Service]
User=sqc
WorkingDirectory=/home/sqc/sqc-main/webapp
ExecStart=/home/sqc/sqc-main/webapp/.venv/bin/python /home/sqc/sqc-main/webapp/app.py
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
